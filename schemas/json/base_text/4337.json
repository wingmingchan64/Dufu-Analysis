{"4337":{"詩題":"見王監兵馬使說，近山有白黑二鷹，羅者久取，竟未能得。王以爲毛骨有異他鷹，恐臘後春生，鶱飛避暖，勁翮思秋之甚，眇不可見，請余賦詩二首","1":{"副題":"其一","5":{"1":{"1":"雲","2":"飛","3":"玉","4":"立","5":"盡","6":"清","7":"秋"},"2":{"1":"不","2":"惜","3":"奇","4":"毛","5":"恣","6":"遠","7":"遊"}},"6":{"1":{"1":"在","2":"野","3":"只","4":"教","5":"心","6":"力","7":"破"},"2":{"1":"千","2":"人","3":"何","4":"事","5":"網","6":"羅","7":"求"}},"7":{"1":{"1":"一","2":"生","3":"自","4":"獵","5":"知","6":"無","7":"敵"},"2":{"1":"百","2":"中","3":"爭","4":"能","5":"恥","6":"下","7":"韝"}},"8":{"1":{"1":"鵬","2":"礙","3":"九","4":"天","5":"須","6":"卻","7":"避"},"2":{"1":"兔","2":"藏","3":"三","4":"穴","5":"莫","6":"深","7":"憂"}}},"2":{"副題":"其二","12":{"1":{"1":"黑","2":"鷹","3":"不","4":"省","5":"人","6":"間","7":"有"},"2":{"1":"度","2":"海","3":"疑","4":"從","5":"北","6":"極","7":"來"}},"13":{"1":{"1":"正","2":"翮","3":"摶","4":"風","5":"超","6":"紫","7":"塞"},"2":{"1":"玄","2":"冬","3":"幾","4":"夜","5":"宿","6":"陽","7":"臺"}},"14":{"1":{"1":"虞","2":"羅","3":"自","4":"各","5":"虛","6":"施","7":"巧"},"2":{"1":"春","2":"雁","3":"同","4":"歸","5":"必","6":"見","7":"猜"}},"15":{"1":{"1":"萬","2":"里","3":"寒","4":"空","5":"祇","6":"一","7":"日"},"2":{"1":"金","2":"眸","3":"玉","4":"爪","5":"不","6":"凡","7":"材"}}}}}
